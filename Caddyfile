{
	email {$CADDY_EMAIL}
}

{$HETZNER_DOMAIN} {
	encode zstd gzip
	basic_auth {
		{$CADDY_BASIC_AUTH_USER} {$CADDY_BASIC_AUTH_HASH}
	}

	handle /api/* {
		reverse_proxy {$VOICE_API_UPSTREAM:legend-voice-api:8787}
	}

	handle /healthz {
		reverse_proxy {$VOICE_API_UPSTREAM:legend-voice-api:8787}
	}

	handle {
		root * /srv/legend
		try_files {path} /index.html
		file_server
	}
}
